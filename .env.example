## Copy to .env (never commit) and fill values
#
# Jira Cloud:   JIRA_BASE_URL=https://your-domain.atlassian.net
# Jira DC/Server: JIRA_BASE_URL=https://jira.yourcompany.com
#
# Required by: scripts/jira_requirements.py create
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Required only by: scripts/jira_requirements.py discover --project-key
# (the 'create' sub-command selects a key automatically)
JIRA_PROJECT_KEY=

# Optional overrides (default: "Epic" / "Story")
# JIRA_EPIC_ISSUETYPE_NAME=
# JIRA_STORY_ISSUETYPE_NAME=
# JIRA_EPIC_NAME_FIELD_ID=
# JIRA_EPIC_LINK_FIELD_ID=

# Required by: scripts/workspace_init.py and other Qase scripts
QASE_API_TOKEN=

